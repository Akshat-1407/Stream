<!DOCTYPE html>
<html>
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0"/>
  <title>Welcome to Stream</title>
</head>

<body style="margin:0;padding:0;background:#0b0b0f;font-family:Arial,sans-serif;">

  <table width="100%" cellpadding="0" cellspacing="0" style="padding:40px 0;">
    <tr>
      <td align="center">

        <!-- Container -->
        <table width="600" cellpadding="0" cellspacing="0" style="background:#15151d;border-radius:14px;overflow:hidden;">

          <!-- Header -->
          <tr>
            <td align="center" style="padding:30px 20px 10px;">
              <!-- <img src="cid:stream-logo" width="70" style="display:block;margin-bottom:10px;" /> -->
              <h1 style="margin:0;color:#ff2d7a;font-size:28px;">Stream</h1>
              <p style="margin:8px 0 0;color:#a1a1aa;font-size:14px;">
                Movies • TV Shows • Anime • Watchlist
              </p>
            </td>
          </tr>

          <!-- Welcome -->
          <tr>
            <td style="padding:30px;color:#ffffff;">
              <h2 style="margin:0 0 10px;color:#cfcfcf">Welcome to Stream, <%= userName %> 👋</h2>

              <p style="color:#cfcfcf;line-height:1.6;font-size:15px;">
                We're excited to have you join Stream. Enjoy a world of movies, TV shows, and anime — all in one place.
              </p>

              <!-- Account Info -->
              <table width="100%" style="margin-top:20px;background:#0f0f14;padding:15px;border-radius:10px;">
                <tr>
                  <td style="color:#a1a1aa;font-size:13px;">
                    <strong style="color:#ffffff;">Name:</strong> <%= userName %><br/>
                    <strong style="color:#ffffff;">Email:</strong> <%= userEmail %>
                  </td>
                </tr>
              </table>

              <!-- Premium Note -->
              <div style="margin-top:20px;padding:12px 15px;border-left:3px solid #ff2d7a;background:#12121a;">
                <p style="margin:0;color:#cfcfcf;font-size:13px;">
                  <strong style="color:#ff2d7a;">Stream Premium:</strong>
                  Upgrade anytime for an enhanced streaming experience.
                </p>
              </div>

              <p style="margin-top:20px;color:#a1a1aa;font-size:12px;">
                © 2026 Stream<br/>
                This is an automated email. Please do not reply.
              </p>

            </td>
          </tr>

        </table>

      </td>
    </tr>
  </table>

</body>
</html>